# ===== OpenClaw workspace paths =====
# OPENCLAW_HOME="$HOME/.openclaw"
# OPENCLAW_WORKSPACE="$OPENCLAW_HOME/workspace"

# ===== FunASR runtime =====
FUNASR_RUNTIME_SCHEME=wss
FUNASR_RUNTIME_HOST=127.0.0.1
FUNASR_RUNTIME_PORT=10095

# ===== LLM bridge =====
VOICE_LLM_CMD='openclaw agent --agent main --message {text}'

# ===== TTS backend =====
VOICE_TTS_BACKEND=mlx
VOICE_TTS_USE_WORKER=1
VOICE_TTS_WORKER_SOCK=/tmp/voice_tts_worker.sock
VOICE_TTS_MLX_MODEL=mlx-community/Qwen3-TTS-12Hz-0.6B-CustomVoice-4bit
VOICE_TTS_MLX_VOICE=Vivian
VOICE_TTS_MLX_LANG=zh
VOICE_TTS_MLX_TEMPERATURE=0.1

# Optional: override mlx-tts python path
# VOICE_MLX_TTS_PY="$OPENCLAW_WORKSPACE/experiments/mlx-tts/.venv/bin/python"
